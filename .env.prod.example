COMPOSE_PROJECT_NAME=system-church-prod
APP_ENV_FILE=.env.prod

POSTGRES_USER=church_user
POSTGRES_PASSWORD=change-prod-password
POSTGRES_DB=church_prod_db

DB_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
NGINX_PORT=8089

DATABASE_URL=postgresql://church_user:change-prod-password@db:5432/church_prod_db
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

SECRET_KEY=change-prod-secret-key
SECRETS_ENCRYPTION_KEY=change-prod-encryption-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=uploads
ATTACHMENT_DIR=uploads/transaction_attachments
TENANT_LOGO_DIR=uploads/tenant_logos
MAX_FILE_SIZE=10485760

BACKEND_CORS_ORIGINS=https://dev.example.com,https://app.example.com

PROJECT_NAME=Church Management System
API_V1_STR=/api/v1
APP_BASE_URL=https://api.example.com
PUBLIC_APP_URL=https://app.example.com

FIRST_SUPERUSER=admin@church.com
FIRST_SUPERUSER_PASSWORD=change-prod-admin-password
FIRST_SUPERUSER_NAME=System Administrator
