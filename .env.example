# Compose / environment selection
COMPOSE_PROJECT_NAME=system-church-dev
APP_ENV_FILE=.env.dev

# Database
POSTGRES_USER=church_user
POSTGRES_PASSWORD=change-password
POSTGRES_DB=church_dev_db
DB_PORT=5434
DATABASE_URL=postgresql://church_user:change-password@localhost:5434/church_dev_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
SECRETS_ENCRYPTION_KEY=your-secrets-encryption-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis / Celery
REDIS_PORT=6380
BACKEND_PORT=8001
NGINX_PORT=8088
REDIS_URL=redis://localhost:6380
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# Upload
UPLOAD_DIR=uploads
ATTACHMENT_DIR=uploads/transaction_attachments
TENANT_LOGO_DIR=uploads/tenant_logos
MAX_FILE_SIZE=10485760

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8088"]

# Project
PROJECT_NAME=Church Financial Management System
API_V1_STR=/api/v1
APP_BASE_URL=http://localhost:8001
PUBLIC_APP_URL=http://localhost:8088

# Bootstrap admin
FIRST_SUPERUSER=admin@church.com
FIRST_SUPERUSER_PASSWORD=change-admin-password
FIRST_SUPERUSER_NAME=System Administrator
