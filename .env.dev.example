COMPOSE_PROJECT_NAME=system-church-dev
APP_ENV_FILE=.env.dev

POSTGRES_USER=church_user
POSTGRES_PASSWORD=change-dev-password
POSTGRES_DB=church_dev_db

DB_PORT=5434
REDIS_PORT=6380
BACKEND_PORT=8001
NGINX_PORT=8088
OLLAMA_PORT=11434
WHATSAPP_GATEWAY_PORT=8091
EVOLUTION_PORT=8092

DATABASE_URL=postgresql://church_user:change-dev-password@localhost:5434/church_dev_db
REDIS_URL=redis://localhost:6380
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120
WHATSAPP_WEBHOOK_URL=http://whatsapp-gateway:8090/send
WHATSAPP_WEBHOOK_TOKEN=dev-whatsapp-gateway-token
WHATSAPP_WEBJS_CLIENT_ID=system-church-dev
WHATSAPP_WEBJS_CONNECT_WAIT_MS=15000
WHATSAPP_WEBJS_AUTOLOAD=true

# Evolution API permanece disponível em dev para compatibilidade,
# mas o QR do sistema passa a ser gerado pelo gateway próprio via whatsapp-web.js.
EVOLUTION_BASE_URL=http://evolution-api:8080
EVOLUTION_SERVER_URL=http://localhost:8092
EVOLUTION_INSTANCE=system-church-dev
EVOLUTION_INSTANCE_TOKEN=system-church-dev-instance-token
EVOLUTION_API_KEY=dev-evolution-api-key
EVOLUTION_WEBHOOK_URL=http://whatsapp-gateway:8090/evolution/webhook
EVOLUTION_MANAGER_URL=http://localhost:8092/manager/
EVOLUTION_WEBHOOK_ENABLED=true
EVOLUTION_PAIRING_NUMBER=
EVOLUTION_SEND_DELAY_MS=1200
EVOLUTION_TIMEOUT_SECONDS=20
EVOLUTION_DB_NAME=evolution_dev
EVOLUTION_DB_USER=evolution
EVOLUTION_DB_PASSWORD=change-evolution-dev-password
EVOLUTION_REDIS_PREFIX=system_church_dev_evolution

# AppKids / Ministerio Infantil
# Needed to enable the child check-in module routes.
CHILD_CHECKIN_DEV_ENABLED=true

SECRET_KEY=change-dev-secret-key
SECRETS_ENCRYPTION_KEY=change-dev-encryption-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=uploads
ATTACHMENT_DIR=uploads/transaction_attachments
TENANT_LOGO_DIR=uploads/tenant_logos
MAX_FILE_SIZE=10485760

BACKEND_CORS_ORIGINS=["https://dev.jpmit.top","http://localhost:3000","http://localhost:8088"]

PROJECT_NAME=Church Management System - Dev
API_V1_STR=/api/v1
APP_BASE_URL=https://dev.jpmit.top
PUBLIC_APP_URL=https://dev.jpmit.top

FIRST_SUPERUSER=admin@church.com
FIRST_SUPERUSER_PASSWORD=change-dev-admin-password
FIRST_SUPERUSER_NAME=System Administrator
