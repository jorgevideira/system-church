COMPOSE_PROJECT_NAME=system-church-dev
APP_ENV_FILE=.env.dev

POSTGRES_USER=church_user
POSTGRES_PASSWORD=change-dev-password
POSTGRES_DB=church_dev_db

DB_PORT=5433
REDIS_PORT=6380
BACKEND_PORT=8001
NGINX_PORT=8088

DATABASE_URL=postgresql://church_user:change-dev-password@localhost:5433/church_dev_db
REDIS_URL=redis://localhost:6380
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

SECRET_KEY=change-dev-secret-key
SECRETS_ENCRYPTION_KEY=change-dev-encryption-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=uploads
ATTACHMENT_DIR=uploads/transaction_attachments
TENANT_LOGO_DIR=uploads/tenant_logos
MAX_FILE_SIZE=10485760

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8088

PROJECT_NAME=Church Management System - Dev
API_V1_STR=/api/v1
APP_BASE_URL=http://localhost:8001
PUBLIC_APP_URL=http://localhost:8088

FIRST_SUPERUSER=admin@church.com
FIRST_SUPERUSER_PASSWORD=change-dev-admin-password
FIRST_SUPERUSER_NAME=System Administrator
